// Alemss - Schema Prisma completo
// Base de datos: PostgreSQL
// ORM: Prisma 5.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTENTICACIÓN (NextAuth.js)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Para login con email/password (bcrypt)
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  priceAlerts  PriceAlert[]
  favorites    Favorite[]
  comparisons  Comparison[]

  @@index([email])
}

enum UserRole {
  USER
  ADMIN
}

// ─────────────────────────────────────────────
// TIENDAS
// ─────────────────────────────────────────────

model Store {
  id          String   @id @default(cuid())
  slug        String   @unique // "falabella", "paris", "ripley"...
  name        String
  displayName String
  url         String
  logoUrl     String?
  logoColor   String?  // Color de marca para UI (#FF6600)
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // Orden de aparición
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  scrapeLogs  ScrapeLog[]

  @@index([slug])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// CATEGORÍAS
// ─────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  displayName String
  icon        String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  level       Int        @default(0) // 0=raíz, 1=sub, 2=sub-sub
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  products    Product[]

  @@index([slug])
  @@index([parentId])
}

// ─────────────────────────────────────────────
// PRODUCTOS
// ─────────────────────────────────────────────

model Product {
  id              String   @id @default(cuid())
  // ID externo del producto en la tienda
  externalId      String
  storeId         String
  categoryId      String?

  // Información básica
  title           String
  slug            String
  brand           String?
  model           String?
  description     String?  @db.Text
  imageUrl        String?
  imageUrls       String[] // Galería de imágenes
  url             String   // URL original en la tienda

  // Precios actuales (desnormalizados para performance)
  currentPrice    Int      // En pesos CLP (sin decimales)
  normalPrice     Int?     // Precio normal/tachado
  cardPrice       Int?     // Precio con tarjeta de la tienda
  minPrice        Int?     // Precio mínimo histórico
  maxPrice        Int?     // Precio máximo histórico

  // Métricas
  discountPercent Int?     // % descuento calculado
  isOnSale        Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  viewCount       Int      @default(0)
  favoriteCount   Int      @default(0)

  // SKU / EAN para matching entre tiendas
  sku             String?
  ean             String?

  // Metadata scraping
  lastScrapedAt   DateTime?
  scrapedVersion  Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store           Store       @relation(fields: [storeId], references: [id])
  category        Category?   @relation(fields: [categoryId], references: [id])
  priceHistory    PriceHistory[]
  priceAlerts     PriceAlert[]
  favorites       Favorite[]
  comparisonItems ComparisonItem[]

  // Índice compuesto para evitar duplicados por tienda
  @@unique([storeId, externalId])
  @@index([storeId])
  @@index([categoryId])
  @@index([slug])
  @@index([brand])
  @@index([currentPrice])
  @@index([discountPercent])
  @@index([isOnSale])
  @@index([isAvailable])
  @@index([lastScrapedAt])
  @@index([createdAt])
  @@index([ean])
}

// ─────────────────────────────────────────────
// HISTORIAL DE PRECIOS
// ─────────────────────────────────────────────

model PriceHistory {
  id              String   @id @default(cuid())
  productId       String
  price           Int      // Precio registrado (CLP)
  normalPrice     Int?
  cardPrice       Int?
  discountPercent Int?
  isAvailable     Boolean  @default(true)
  source          String?  // "scraper", "manual", "api"
  recordedAt      DateTime @default(now())

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([recordedAt])
  @@index([productId, recordedAt])
}

// ─────────────────────────────────────────────
// ALERTAS DE PRECIO
// ─────────────────────────────────────────────

model PriceAlert {
  id          String      @id @default(cuid())
  userId      String
  productId   String
  targetPrice Int         // Precio objetivo en CLP
  isActive    Boolean     @default(true)
  triggeredAt DateTime?   // Cuándo se disparó
  notifiedAt  DateTime?   // Cuándo se notificó al usuario
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // Un usuario una alerta por producto
  @@index([userId])
  @@index([productId])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// FAVORITOS
// ─────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// COMPARADOR DE PRODUCTOS
// ─────────────────────────────────────────────

model Comparison {
  id        String           @id @default(cuid())
  userId    String
  name      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ComparisonItem[]

  @@index([userId])
}

model ComparisonItem {
  id           String     @id @default(cuid())
  comparisonId String
  productId    String
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())

  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([comparisonId, productId])
  @@index([comparisonId])
}

// ─────────────────────────────────────────────
// LOGS DE SCRAPING
// ─────────────────────────────────────────────

model ScrapeLog {
  id              String      @id @default(cuid())
  storeId         String
  status          ScrapeStatus
  productsFound   Int         @default(0)
  productsUpdated Int         @default(0)
  productsNew     Int         @default(0)
  priceChanges    Int         @default(0)
  errors          String[]
  durationMs      Int?
  startedAt       DateTime    @default(now())
  finishedAt      DateTime?

  store           Store       @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([status])
  @@index([startedAt])
}

enum ScrapeStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// ─────────────────────────────────────────────
// BÚSQUEDAS POPULARES (para autocompletado)
// ─────────────────────────────────────────────

model SearchQuery {
  id        String   @id @default(cuid())
  query     String   @unique
  count     Int      @default(1)
  lastUsed  DateTime @default(now())

  @@index([count])
  @@index([query])
}
